# Discord webhook for alerts/digests. Create one in Discord:
#   Server settings -> Integrations -> Webhooks -> New Webhook -> Copy URL
DISCORD_WEBHOOK_URL=

# Optional: separate webhook for daily digests vs urgent alerts
DISCORD_DIGEST_WEBHOOK_URL=

# Polymarket API base URLs (rarely need changing)
POLYMARKET_DATA_API=https://data-api.polymarket.com
POLYMARKET_GAMMA_API=https://gamma-api.polymarket.com

# Kalshi API (https://trading-api.readme.io). Public read endpoints don't need a key.
KALSHI_API_BASE=https://api.elections.kalshi.com/trade-api/v2

# Signal thresholds
TOP_N_TRADERS=50
LEADERBOARD_TIME_PERIOD=MONTH       # DAY | WEEK | MONTH | ALL
LEADERBOARD_ORDER_BY=PNL            # PNL | VOL
MIN_TRADERS_PER_MARKET=4
MIN_CONSENSUS_SCORE=0.15
MIN_MARKET_VOLUME_USD=10000
MIN_MINUTES_TO_RESOLUTION=60        # skip markets resolving in <1h
MAX_DAYS_TO_RESOLUTION=7            # skip markets resolving > N days out (default 7 = fast feedback)
EDGE_THRESHOLD=0.08                 # |consensus_prob - market_price| to flag as edge

# Bet sizing (recommendation only — does not place real orders)
BANKROLL_USD=1000          # total $ allocated to this strategy
KELLY_FRACTION=0.25        # fractional Kelly (0.25 = quarter-Kelly, conservative)
MAX_BET_PCT=0.05           # hard cap: never bet more than this % of bankroll on one event
DAILY_EXPOSURE_CAP=0.20    # if sum of bets exceeds this % of bankroll, scale all down proportionally

# Storage
DB_PATH=data/copytrader.db
